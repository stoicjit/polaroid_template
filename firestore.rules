rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function uploadsEnabled() {
      return exists(/databases/$(database)/documents/settings/app)
        && get(/databases/$(database)/documents/settings/app).data.uploadsEnabled == true;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }

    match /photos/{photoId} {
      allow read: if true;

      allow create: if signedIn()
        && uploadsEnabled()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.url is string
        && (request.resource.data.createdAt == request.time
          || request.resource.data.createdAt is timestamp)
        && request.resource.data.note is string
        && request.resource.data.note.size() > 0
        && request.resource.data.note.size() <= 120;

      allow update: if false;
    }
  }
}
